EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
EXPO_PUBLIC_ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Google Maps API key — enables address autocomplete in the trip creation form
# Required APIs: Places API, Maps SDK for iOS
# Get one at: https://console.cloud.google.com/apis/credentials
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
